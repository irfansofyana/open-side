{
  "manifest_version": 3,
  "name": "OpenSide",
  "short_name": "OpenSide",
  "version": "0.1.0",
  "description": "OpenSide browser companion for Open WebUI.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting", "tabs"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background/serviceWorker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "OpenSide"
  }
}
